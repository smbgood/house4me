{
  "manifest_version": 3,
  "name": "House4Me Trulia Scanner",
  "version": "1.0.0",
  "description": "Scan the current Trulia page and send listings to House4Me ingest.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "*://*.trulia.com/*",
    "http://localhost:9999/*",
    "https://*.netlify.app/*"
  ],
  "action": {
    "default_title": "Trulia Scanner",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://*.trulia.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
